{
  "manifest_version": 2,
  "name": "Search Language Switch",
  "version": "0.1.0",
  "description": "Forces Google Search UI and results language to English.",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "search-language-switch@example.com",
      "strict_min_version": "68.0"
    }
  },
  "icons": {
    "16": "./assets/logo/logo-16x16.png",
    "32": "./assets/logo/logo-32x32.png",
    "48": "./assets/logo/logo-48x48.png",
    "128": "./assets/logo/logo-128x128.png"
  }
}
